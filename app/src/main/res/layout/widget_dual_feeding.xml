<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@android:color/transparent"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/notif_title"
        android:textStyle="bold"
        android:textSize="16sp" />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:paddingEnd="4dp">

            <TextView
                android:id="@+id/widget_child1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_1_label"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_child1_last"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="--" />

            <TextView
                android:id="@+id/widget_child1_elapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="--" />

            <Button
                android:id="@+id/widget_child1_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_mark_fed_child_1"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:paddingStart="4dp">

            <TextView
                android:id="@+id/widget_child2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/child_2_label"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_child2_last"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="--" />

            <TextView
                android:id="@+id/widget_child2_elapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="--" />

            <Button
                android:id="@+id/widget_child2_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_mark_fed_child_2"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

